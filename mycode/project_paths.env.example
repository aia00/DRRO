# Global path config for DRRO scripts.
# Copy to mycode/project_paths.env and edit for your machine.
# You can override file location with: export DRRO_PATH_CONFIG=/path/to/your.env

# Optional local HH-RLHF dataset directory for python training scripts.
# Leave empty to use remote dataset loading.
DRRO_LOCAL_DATASET_DIR=

# Ray temp directory used by run scripts and trainer config.
DRRO_RAY_TMPDIR=./ray_tmp

# Default output root for bash launchers.
DRRO_OUTPUT_ROOT=./runs

# Default proxy-pairs directory for proxy RM utilities.
# Must contain train.jsonl and val.jsonl.
DRRO_PROXY_PAIRS_DIR=./runs/proxy_pairs/proxy_pairs_50k

# Optional explicit VERL root. Leave empty to auto-discover.
DRRO_VERL_ROOT=
